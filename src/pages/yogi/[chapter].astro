---
// src/pages/yogi/[chapter].astro
import rawHtml from '../../data/yogi.html?raw';

export async function getStaticPaths() {
  // Remove all images and their direct captions 
  let noImagesHtml = rawHtml.replace(/<div class="calibre3">\s*<img[^>]*>\s*<\/div>(?:\s*<div class="calibre(?:11|14|6)">[\s\S]*?<\/div>|\s*<div class="calibre18">\s*<\/div>)*/gi, '');

  // Extract all footnotes from the bottom of the book so we can inject them invisibly for the popup to read
  const footnotesRegex = /<div class="calibre12">\s*<div class="calibre17">\s*<a id="calibre_link-\d+" href="#calibre_link-\d+" class="calibre9">\d+<\/a>[\s\S]*?<\/div>\s*<\/div>/gi;
  const allFootnotesMatches = [...noImagesHtml.matchAll(footnotesRegex)];
  const allFootnotesHtml = allFootnotesMatches.map(m => m[0]).join('\n');

  // Split into chapters by the strict CHAPTER heading structure inside the HTML
  const chapterParts = noImagesHtml.split(/<div class="calibre10">\s*<span class="calibre4">\s*<span class="bold">\s*CHAPTER(?:[^<]*|<\/?span[^>]*>)*<\/div>/i);
  
  // The first part is front-matter. Chapters are exactly indices 1 through 48.
  const rawChapters = chapterParts.slice(1, 49);

  const chapterTitles = [
    "My Parents and Early Life", "My Mother’s Death and the Mystic Amulet", "The Saint with Two Bodies",
    "My Interrupted Flight Toward the Himalayas", "A “Perfume Saint” Displays his Wonders",
    "The Tiger Swami", "The Levitating Saint", "India’s Great Scientist, J. C. Bose",
    "The Blissful Devotee and his Cosmic Romance", "I Meet my Master, Sri Yukteswar",
    "Two Penniless Boys in Brindaban", "Years in my Master’s Hermitage", "The Sleepless Saint",
    "An Experience in Cosmic Consciousness", "The Cauliflower Robbery", "Outwitting the Stars",
    "Sasi and the Three Sapphires", "A Mohammedan Wonder-Worker",
    "My Master, in Calcutta, appears in Serampore", "We Do Not Visit Kashmir",
    "We Visit Kashmir", "The Heart of a Stone Image", "My University Degree",
    "I Become a Monk of the Swami Order", "Brother Ananda and Sister Nalini",
    "The Science of Kriya Yoga", "Founding a Yoga School at Ranchi",
    "Kashi, Reborn and Rediscovered", "Rabindranath Tagore and I Compare Schools",
    "The Law of Miracles", "An Interview with the Sacred Mother", "Rama is Raised from the Dead",
    "Babaji, the Yogi-Christ of Modern India", "Materializing a Palace in the Himalayas",
    "The Christlike Life of Lahiri Mahasaya", "Babaji’s Interest in the West", "I Go to America",
    "Luther Burbank — An American Saint", "Therese Neumann, the Catholic Stigmatist",
    "I Return to India", "An Idyl in South India", "Last Days with my Guru",
    "The Resurrection of Sri Yukteswar", "With Mahatma Gandhi at Wardha",
    "The Bengali “Joy-Permeated Mother”", "The Woman Yogi who Never Eats",
    "I Return to the West", "At Encinitas in California"
  ];

  return chapterTitles.map((title, index) => {
    const chapterNumber = index + 1;
    let content = rawChapters[index] || "Chapter content missing.";

    // Remove the repeated chapter title bleeding into the text body
    content = content.replace(/^[\s\S]*?(?=<div class="calibre(?:18|12)">)/i, '');

    // For chapter 48, truncate exactly after the final paragraph you specified
    if (chapterNumber === 48) {
        const endPhrase = "overcoming of all human misery";
        const phraseIndex = content.indexOf(endPhrase);
        if (phraseIndex !== -1) {
            // Find the closing tag of that paragraph so the HTML remains perfectly valid
            const closeDivIndex = content.indexOf('</div>', phraseIndex);
            if (closeDivIndex !== -1) {
                // Slices off everything after this paragraph (Index, Notes, visible Footnotes)
                content = content.substring(0, closeDivIndex + 6);
            }
        }
    }

    return {
      params: { chapter: chapterNumber.toString() },
      props: {
        chapterNumber,
        title,
        content,
        allTitles: chapterTitles,
        allFootnotesHtml // Passed down so the modal can access it invisibly
      }
    };
  });
}

const { chapterNumber, title, content, allTitles, allFootnotesHtml } = Astro.props;
const totalChapters = allTitles.length;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><path d='M12,22C12,22 4,16 4,12C4,8 12,2 12,2C12,2 20,8 20,12C20,16 12,22 12,22M12,4C12,4 7,8.5 7,12C7,15.5 12,19 12,19C12,19 17,15.5 17,12C17,8.5 12,4 12,4Z'/></svg>">
    
    <style is:global>
        :root {
            --bg: #030303;
            --text-main: #f3f4f6;
            --accent: #ca9f1b;
            --card-bg: rgba(14, 14, 14, 0.75);
            --card-border: rgba(214, 175, 55, 0.15);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            min-height: 100vh;
            background-color: var(--bg);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            padding: 4rem 2rem;
            box-sizing: border-box;
        }

        .bg-image {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: url('/paramahansa-yogananda-photo-2-5-x-3-5-yss-front-600x858.webp');
            background-size: cover;
            background-position: center 20%;
            z-index: -1;
            filter: brightness(0.35) saturate(1.2) blur(3px);
        }

        .content-container {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--card-border);
            border-radius: 1rem;
            padding: 3.5rem;
            max-width: 750px;
            width: 100%;
            margin: 0 auto;
            box-shadow: 0 24px 50px rgba(0,0,0,0.8);
        }

        .navigation-header { 
            display: flex; 
            justify-content: flex-end; /* Adjusted to keep the select dropdown on the right */
            align-items: center; 
            margin-bottom: 2.5rem; 
        }
        
        .back-btn {
            position: fixed; 
            top: 1.5rem; 
            left: 1.5rem; 
            z-index: 999;
            display: inline-flex; align-items: center; gap: 0.5rem;
            color: var(--text-main); text-decoration: none; font-size: 0.8rem; font-weight: 700;
            font-family: 'JetBrains Mono', monospace; text-transform: uppercase;
            background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            padding: 0.5rem 1rem; border-radius: 100px; transition: all 0.2s;
        }

        .back-btn:hover { background: rgba(255, 255, 255, 0.1); border-color: var(--accent); }

        h1 { color: var(--accent); text-align: center; margin-bottom: 2rem; font-size: 1.8rem; text-transform: uppercase; }
        
        /* NEW: Added subtitle class matching your other files */
        .subtitle {
            text-align: center;
            color: #888;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9rem;
            margin-bottom: 2.5rem;
        }

        .text-body {
            line-height: 1.8; font-size: 1.05rem;
            color: rgba(243, 244, 246, 0.9);
        }

        /* Essential spacing classes injected natively by the HTML file */
        .text-body .calibre12, .text-body .calibre18 { margin-bottom: 1.2rem; }
        .text-body .italic { font-style: italic; }
        .text-body .bold { font-weight: bold; }
        .text-body .calibre11, .text-body .calibre6 { display: none; }
        .text-body sup { font-size: 0.75rem; vertical-align: super; }
        .text-body a { color: var(--accent); text-decoration: none; font-weight: bold; cursor: pointer;}
        .text-body a:hover { text-decoration: underline; }
        .text-body .calibre16 { margin-left: 1.5rem; font-style: italic; border-left: 2px solid var(--accent); padding-left: 1rem; }

        .chapter-selector {
            background: rgba(14, 14, 14, 0.8); border: 1px solid var(--card-border);
            color: var(--text-main); padding: 0.5rem; border-radius: 0.5rem;
            font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;
            cursor: pointer; outline: none; max-width: 60%;
        }

        .pagination-footer {
            display: flex; justify-content: space-between; margin-top: 4rem;
            padding-top: 2rem; border-top: 1px solid rgba(214, 175, 55, 0.1);
        }

        .nav-link {
            color: var(--text-main); text-decoration: none; font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem; font-weight: 700; transition: color 0.2s;
        }
        .nav-link:hover { color: var(--accent); }

        /* Footnote UI Structure */
        .footnote-modal {
            display: none; position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%);
            background: rgba(14, 14, 14, 0.95); backdrop-filter: blur(20px);
            border: 1px solid var(--accent); border-radius: 1rem; padding: 2rem;
            max-width: 600px; width: 90%; box-shadow: 0 24px 50px rgba(0,0,0,0.9);
            z-index: 1000; text-align: left;
        }
        .footnote-modal.active { display: block; }
        .footnote-close {
            background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.2);
            color: var(--text-main); padding: 0.5rem 1rem; border-radius: 100px;
            cursor: pointer; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem;
            margin-top: 1.5rem; display: inline-block; transition: all 0.2s;
        }
        .footnote-close:hover { border-color: var(--accent); }

        @media (max-width: 768px) { .content-container { padding: 2rem; } .chapter-selector { max-width: 50%; } }
    </style>
</head>
<body>
    <div class="bg-image"></div>
    
    <a href="/" class="back-btn">← Back</a>

    <div class="content-container">
        <div class="navigation-header">
            <select class="chapter-selector" onchange="window.location.href='/yogi/' + this.value">
                {allTitles.map((t, idx) => (
                    <option value={idx + 1} selected={idx + 1 === chapterNumber}>
                        {t}
                    </option>
                ))}
            </select>
        </div>
        
        <h1 style={chapterNumber === 1 ? 'margin-bottom: 0.5rem;' : ''}>{title}</h1>
        {chapterNumber === 1 && <p class="subtitle">Paramahansa Yogananda</p>}
        
        <div class="text-body" set:html={content}></div>

        <div class="pagination-footer">
            {chapterNumber > 1 ? (
                <a href={`/yogi/${chapterNumber - 1}`} class="nav-link">← Prev</a>
            ) : <div />}
            
            {chapterNumber < totalChapters ? (
                <a href={`/yogi/${chapterNumber + 1}`} class="nav-link">Next →</a>
            ) : <div />}
        </div>
    </div>

    <div id="footnote-modal" class="footnote-modal">
        <div id="footnote-content" class="text-body"></div>
        <button class="footnote-close" id="close-footnote">← Back to Text</button>
    </div>

    <div id="all-footnotes-container" style="display: none;" set:html={allFootnotesHtml}></div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('footnote-modal');

            // Listen for clicks on the superscript footnote links
            document.querySelectorAll('a.calibre9').forEach(link => {
                if(link.querySelector('sup')) {
                    link.addEventListener('click', (e) => {
                        e.preventDefault();
                        const targetId = link.getAttribute('href').substring(1);
                        const footnoteEl = document.getElementById(targetId);
                        if (footnoteEl) {
                            // Extract the text and show the modal
                            document.getElementById('footnote-content').innerHTML = footnoteEl.parentElement.innerHTML;
                            modal.classList.add('active');
                        }
                    });
                }
            });

            // Close modal button
            document.getElementById('close-footnote').addEventListener('click', () => {
                modal.classList.remove('active');
            });

            // If the user clicks the number *inside* the modal, just close the modal instead of scrolling
            document.getElementById('footnote-content').addEventListener('click', (e) => {
                if(e.target.tagName === 'A') {
                    e.preventDefault();
                    modal.classList.remove('active');
                }
            });

            // Close on Esc key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && modal.classList.contains('active')) {
                    modal.classList.remove('active');
                }
            });

            // Close on clicking/tapping outside the modal
            document.addEventListener('click', (e) => {
                if (modal.classList.contains('active') && 
                    !modal.contains(e.target) && 
                    !e.target.closest('a.calibre9')) {
                    modal.classList.remove('active');
                }
            });
        });
    </script>
</body>
</html>