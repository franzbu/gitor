---
// src/pages/index.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>God Is The Only Reality</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><path d='M12,22C12,22 4,16 4,12C4,8 12,2 12,2C12,2 20,8 20,12C20,16 12,22 12,22M12,4C12,4 7,8.5 7,12C7,15.5 12,19 12,19C12,19 17,15.5 17,12C17,8.5 12,4 12,4Z'/></svg>">
    <style is:global>
        :root {
            --bg: #030303;
            --card-bg: rgba(14, 14, 14, 0.65);
            --card-border: rgba(214, 175, 55, 0.09);
            --accent: #ca9f1b;
            --text-main: #f3f4f6;
        }
        
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text-main);
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background-image: 
                radial-gradient(circle at 0% 0%, rgba(214, 175, 55, 0.04), transparent 45%),
                radial-gradient(circle at 100% 100%, rgba(16, 185, 129, 0.02), transparent 45%);
        }

        .container { text-align: center; max-width: 900px; width: 100%; padding: 2rem; }

        h1 { 
            font-size: clamp(2rem, 8vw, 3.5rem); 
            margin-bottom: 4rem; 
            background: linear-gradient(135deg, #fff 50%, var(--accent));
            -webkit-background-clip: text; 
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .nav-grid { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }

        .link-card {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            padding: 1.5rem 3rem;
            border-radius: 1rem;
            text-decoration: none;
            color: var(--text-main);
            font-weight: 600;
            font-family: 'JetBrains Mono', monospace;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            backdrop-filter: blur(20px);
            min-width: 220px;
        }

        .link-card:hover {
            border-color: rgba(214, 175, 55, 0.4);
            transform: translateY(-4px);
            box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.7);
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>God Is The Only Reality</h1>
        <div class="nav-grid">
            <a href="/friendship" class="link-card">Friendship</a>
            <a href="/gitanjali" class="link-card">Gitanjali</a>
            <a href="/samadhi" class="link-card">Samadhi</a>
            <a href="/yogi/1" class="link-card">Autobiography of a Yogi</a>
        </div>
    </div>
</body>
</html>