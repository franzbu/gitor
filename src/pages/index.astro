---
// src/pages/index.astro
import fileContent from '../data/spiritual_diary.txt?raw';
import quotesContent from '../data/quotes.txt?raw';

// 1. Server-side fallback: Keeps the Rome timezone so the page never loads blank
const options = { timeZone: 'Europe/Rome', month: 'long', day: 'numeric' };
const todayStr = new Intl.DateTimeFormat('en-US', options).format(new Date());

const regex = new RegExp(`\\*\\s+${todayStr}:\\s+"(.*?)"\\s+[—-]\\s+([^\\n\\r]+)`, 'i');
const match = fileContent.match(regex);

const quote = match ? match[1] : "Begin each day with a heart full of gratitude.";
const citation = match ? match[2] : "Paramahansa Yogananda";

// 2. Calculate the total number of quotes by counting the citation blocks
const totalQuotes = [...quotesContent.matchAll(/([\s\S]+?)\n[-—―][^\n]+/g)].length;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>God Is The Only Reality</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><path d='M12,22C12,22 4,16 4,12C4,8 12,2 12,2C12,2 20,8 20,12C20,16 12,22 12,22M12,4C12,4 7,8.5 7,12C7,15.5 12,19 12,19C12,19 17,15.5 17,12C17,8.5 12,4 12,4Z'/></svg>">
    <style is:global>
        :root {
            --bg: #030303;
            --text-main: #f3f4f6;
            --accent: #ca9f1b;
            --card-bg: rgba(14, 14, 14, 0.75);
            --card-border: rgba(214, 175, 55, 0.15);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text-main);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            position: relative;
        }

        /* Dynamically resizing Om background using the attached SVG as a mask */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: var(--accent);
            opacity: 0.11;
            -webkit-mask: url('/Om_symbol.svg') no-repeat center / 100vmin;
            mask: url('/Om_symbol.svg') no-repeat center / 100vmin;
            z-index: -1;
            pointer-events: none;
        }

        .container { text-align: center; padding: 2rem;
        }

        /* Quote Styles */
        .daily-quote { margin-bottom: 2rem;
        max-width: 700px; margin-left: auto; margin-right: auto; }
        
        /* white-space: pre-wrap added here to respect empty lines in quotes */
        .quote { font-style: italic;
        font-size: 1.3rem; line-height: 1.6; color: var(--text-main); margin-bottom: 0.75rem; white-space: pre-wrap;
        }
        .citation { font-size: 0.85rem; color: #888; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em;
        }

        h1 { 
            font-size: 3.5rem;
            margin: 3.5rem 0; /* Addressed spacing: more room before and after */
            background: linear-gradient(to right, var(--text-main) 50%, var(--accent));
            -webkit-background-clip: text; 
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .nav-grid { display: flex;
        gap: 1.5rem; justify-content: center; flex-wrap: wrap; }

        .link-card {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            padding: 1.5rem 3rem;
            border-radius: 1rem;
            text-decoration: none;
            color: var(--text-main);
            font-weight: 600;
            font-family: 'JetBrains Mono', monospace;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            backdrop-filter: blur(20px);
            min-width: 220px;
        }

        .link-card:hover {
            border-color: rgba(214, 175, 55, 0.4);
            transform: translateY(-4px);
            box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.7);
        }

        /* NEW: Isolated spacing just for the bottom quote so nothing else is affected */
        .footer-quote { margin-top: 20rem;
        margin-bottom: 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="daily-quote">
            <p class="quote" id="daily-quote-text">"{quote}"</p>
            <p class="citation" id="daily-citation-text">{citation}</p>
        </div>

        <h1>God Is The Only Reality</h1>
        
        <div class="nav-grid">
            <a href="/autobiography/1" class="link-card">Autobiography of a Yogi</a>
            <a href="/gita/2/" class="link-card">Bhagavad Gita</a>
            <a href="/bible/1/" class="link-card">Bible - King James Version</a>
            <a href="/lawrence/2/" class="link-card">The Practice of the Presence of God</a>
            <a href="/plato_allegory" class="link-card">Allegory of the Cave</a>
            <a href="/samadhi" class="link-card">Samadhi</a>
            <a href="/friendship" class="link-card">Friendship</a>
            <a href="/gitanjali" class="link-card">Gitanjali</a>
            <a href="/you" class="link-card">You</a>
        </div>

        <div class="daily-quote footer-quote">
            <p class="quote" id="hourly-quote-text"></p>
            <p class="citation" id="hourly-citation-text"></p>
        </div>
    </div>

    <script define:vars={{ fileContent, totalQuotes }}>
        // --- 1. DAILY SPIRITUAL DIARY QUOTE ---
        const now = new Date();
        const options = { month: 'long', day: 'numeric' };
        const localTodayStr = new Intl.DateTimeFormat('en-US', options).format(now);

        const regex = new RegExp(`\\*\\s+${localTodayStr}:\\s+"(.*?)"\\s+[—-]\\s+([^\\n\\r]+)`, 'i');
        const match = fileContent.match(regex);

        if (match) {
            const quoteEl = document.getElementById('daily-quote-text');
            const citationEl = document.getElementById('daily-citation-text');
            
            if(quoteEl && citationEl) {
                quoteEl.textContent = `"${match[1]}"`;
                citationEl.textContent = match[2];
            }
        }

        // --- 2. 6-HOURLY RANDOM FOOTER QUOTE (FETCHED DYNAMICALLY) ---
        if (totalQuotes > 0) {
            // Function to generate a unique integer seed for the current 6-hour block in Rome time
            const getRomeBlock = (timestamp) => {
                const parts = new Intl.DateTimeFormat('en-US', { 
                    timeZone: 'Europe/Rome', year: 'numeric', month: 'numeric', day: 'numeric', hour: 'numeric', hourCycle: 'h23' 
                }).formatToParts(new Date(timestamp));
                
                let y, m, d, h;
                for (const p of parts) {
                    if (p.type === 'year') y = p.value;
                    if (p.type === 'month') m = p.value;
                    if (p.type === 'day') d = p.value;
                    if (p.type === 'hour') h = parseInt(p.value, 10);
                }
                const block = Math.floor(h / 6); // Gives 0, 1, 2, or 3
                return parseInt(`${y}${m.padStart(2, '0')}${d.padStart(2, '0')}${block}`);
            };

            const nowMs = Date.now();
            const currentPeriod = getRomeBlock(nowMs);
            const prevPeriod = getRomeBlock(nowMs - (6 * 3600000)); // 6 hours ago

            // Simple seeded random function
            const seededRandom = (seed) => {
                const x = Math.sin(seed) * 10000;
                return x - Math.floor(x);
            };

            let idx = Math.floor(seededRandom(currentPeriod) * totalQuotes);
            let prevIdx = Math.floor(seededRandom(prevPeriod) * totalQuotes);
            
            // Ensure the quote is never the same as the previous 6-hour block's quote
            if (idx === prevIdx && totalQuotes > 1) {
                idx = (idx + 1) % totalQuotes;
            }

            // Fetch ONLY the specific quote fragment needed for this 6-hour block
            fetch(`/quotes/quote-${idx}.txt`)
                .then(response => response.text())
                .then(text => {
                    const blockMatch = text.match(/([\s\S]+?)\n[-—―]\s*(.*)/);
                    if (blockMatch) {
                        const rawQuote = blockMatch[1].trim();
                        const rawCitation = blockMatch[2].trim();
                        
                        const hourlyQuoteEl = document.getElementById('hourly-quote-text');
                        const hourlyCitationEl = document.getElementById('hourly-citation-text');

                        if (hourlyQuoteEl && hourlyCitationEl) {
                            const hasQuotes = rawQuote.startsWith('"') || rawQuote.startsWith('“');
                            hourlyQuoteEl.textContent = hasQuotes ? rawQuote : `"${rawQuote}"`;
                            hourlyCitationEl.textContent = rawCitation;
                        }
                    }
                })
                .catch(error => console.error('Error fetching quote:', error));
        }

        // --- 3. AUTO-REFRESH AT THE NEXT 6-HOUR MARK (Rome Time) ---
        // Calculate the exact milliseconds remaining until the next 00:00, 06:00, 12:00, or 18:00 in Rome
        const timeParts = new Intl.DateTimeFormat('en-US', { 
            timeZone: 'Europe/Rome', hour: 'numeric', minute: 'numeric', second: 'numeric', hourCycle: 'h23' 
        }).formatToParts(new Date());
        
        let rH = 0, rM = 0, rS = 0;
        for (const p of timeParts) {
            if (p.type === 'hour') rH = parseInt(p.value, 10);
            if (p.type === 'minute') rM = parseInt(p.value, 10);
            if (p.type === 'second') rS = parseInt(p.value, 10);
        }

        const msIntoBlock = ((rH % 6) * 3600000) + (rM * 60000) + (rS * 1000) + new Date().getMilliseconds();
        const msUntilNextBlock = (6 * 3600000) - msIntoBlock + 1000; // Add 1s safety buffer
        
        setTimeout(() => {
            window.location.reload();
        }, msUntilNextBlock);
    </script>
</body>
</html>