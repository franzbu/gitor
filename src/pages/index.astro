---
// src/pages/index.astro
import fileContent from '../data/spiritual_diary.txt?raw';
import quotesContent from '../data/quotes.txt?raw';

// 1. Server-side fallback: Keeps the Rome timezone so the page never loads blank
const options = { timeZone: 'Europe/Rome', month: 'long', day: 'numeric' };
const todayStr = new Intl.DateTimeFormat('en-US', options).format(new Date());

const regex = new RegExp(`\\*\\s+${todayStr}:\\s+"(.*?)"\\s+[—-]\\s+([^\\n\\r]+)`, 'i');
const match = fileContent.match(regex);

const quote = match ? match[1] : "Begin each day with a heart full of gratitude.";
const citation = match ? match[2] : "Paramahansa Yogananda";

// 2. Calculate the total number of quotes on the server so the text isn't leaked to the client
const totalQuotes = quotesContent.split(/\n\s*\n+/).filter(b => b.trim().length > 0 && !b.startsWith('_')).length;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>God Is The Only Reality</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><path d='M12,22C12,22 4,16 4,12C4,8 12,2 12,2C12,2 20,8 20,12C20,16 12,22 12,22M12,4C12,4 7,8.5 7,12C7,15.5 12,19 12,19C12,19 17,15.5 17,12C17,8.5 12,4 12,4Z'/></svg>">
    <style is:global>
        :root {
            --bg: #030303;
            --text-main: #f3f4f6;
            --accent: #ca9f1b;
            --card-bg: rgba(14, 14, 14, 0.75);
            --card-border: rgba(214, 175, 55, 0.15);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text-main);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            position: relative;
        }

        /* Dynamically resizing Om background using the attached SVG as a mask */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: var(--accent);
            opacity: 0.11;
            -webkit-mask: url('/Om_symbol.svg') no-repeat center / 100vmin;
            mask: url('/Om_symbol.svg') no-repeat center / 100vmin;
            z-index: -1;
            pointer-events: none;
        }

        .container { text-align: center; padding: 2rem; }

        /* Quote Styles */
        .daily-quote { margin-bottom: 2rem; max-width: 700px; margin-left: auto; margin-right: auto; }
        .quote { font-style: italic; font-size: 1.3rem; line-height: 1.6; color: var(--text-main); margin-bottom: 0.75rem; }
        .citation { font-size: 0.85rem; color: #888; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em; }

        h1 { 
            font-size: 3.5rem; 
            margin: 3.5rem 0; /* Addressed spacing: more room before and after */
            background: linear-gradient(to right, var(--text-main) 50%, var(--accent));
            -webkit-background-clip: text; 
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .nav-grid { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }

        .link-card {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            padding: 1.5rem 3rem;
            border-radius: 1rem;
            text-decoration: none;
            color: var(--text-main);
            font-weight: 600;
            font-family: 'JetBrains Mono', monospace;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            backdrop-filter: blur(20px);
            min-width: 220px;
        }

        .link-card:hover {
            border-color: rgba(214, 175, 55, 0.4);
            transform: translateY(-4px);
            box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.7);
        }

        /* NEW: Isolated spacing just for the bottom quote so nothing else is affected */
        .footer-quote { margin-top: 20rem; margin-bottom: 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="daily-quote">
            <p class="quote" id="daily-quote-text">"{quote}"</p>
            <p class="citation" id="daily-citation-text">{citation}</p>
        </div>

        <h1>God Is The Only Reality</h1>
        
        <div class="nav-grid">
            <a href="/yogi/1" class="link-card">Autobiography of a Yogi</a>
            <a href="/samadhi" class="link-card">Samadhi</a>
            <a href="/friendship" class="link-card">Friendship</a>
            <a href="/gitanjali" class="link-card">Gitanjali</a>
            <a href="/you" class="link-card">You</a>
            <a href="/plato_allegory" class="link-card">Allegory of the Cave</a>
        </div>

        <div class="daily-quote footer-quote">
            <p class="quote" id="hourly-quote-text">"We are such stuff as dreams are made on; and our little life is rounded with a sleep."</p>
            <p class="citation" id="hourly-citation-text">Shakespeare, The Tempest</p>
        </div>
    </div>

    <script define:vars={{ fileContent, totalQuotes }}>
        // --- 1. DAILY SPIRITUAL DIARY QUOTE ---
        const now = new Date();
        const options = { month: 'long', day: 'numeric' };
        const localTodayStr = new Intl.DateTimeFormat('en-US', options).format(now);

        const regex = new RegExp(`\\*\\s+${localTodayStr}:\\s+"(.*?)"\\s+[—-]\\s+([^\\n\\r]+)`, 'i');
        const match = fileContent.match(regex);

        if (match) {
            const quoteEl = document.getElementById('daily-quote-text');
            const citationEl = document.getElementById('daily-citation-text');
            
            if(quoteEl && citationEl) {
                quoteEl.textContent = `"${match[1]}"`;
                citationEl.textContent = match[2];
            }
        }

        // --- 2. HOURLY RANDOM FOOTER QUOTE (FETCHED DYNAMICALLY) ---
        if (totalQuotes > 0) {
            const currentHour = Math.floor(Date.now() / 3600000);
            
            // Simple seeded random function to ensure the quote stays the same for the entire hour
            const seededRandom = (seed) => {
                const x = Math.sin(seed) * 10000;
                return x - Math.floor(x);
            };

            let idx = Math.floor(seededRandom(currentHour) * totalQuotes);
            let prevIdx = Math.floor(seededRandom(currentHour - 1) * totalQuotes);

            // Ensure the quote is never the same as the previous hour's quote
            if (idx === prevIdx && totalQuotes > 1) {
                idx = (idx + 1) % totalQuotes;
            }

            // Fetch ONLY the specific quote fragment needed for this hour
            fetch(`/quotes/quote-${idx}.txt`)
                .then(response => response.text())
                .then(text => {
                    const blockMatch = text.match(/([\s\S]+?)\n[-—―]\s*(.*)/);
                    if (blockMatch) {
                        const rawQuote = blockMatch[1].trim();
                        const rawCitation = blockMatch[2].trim();
                        
                        const hourlyQuoteEl = document.getElementById('hourly-quote-text');
                        const hourlyCitationEl = document.getElementById('hourly-citation-text');

                        if (hourlyQuoteEl && hourlyCitationEl) {
                            // Ensure wrapping quotes if they aren't included in the raw text
                            const hasQuotes = rawQuote.startsWith('"') || rawQuote.startsWith('“');
                            hourlyQuoteEl.textContent = hasQuotes ? rawQuote : `"${rawQuote}"`;
                            hourlyCitationEl.textContent = rawCitation;
                        }
                    }
                })
                .catch(error => console.error('Error fetching quote:', error));
        }
    </script>
</body>
</html>